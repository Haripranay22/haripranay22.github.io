# AnalystIQ Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=analystiq
DB_USER=postgres
DB_PASSWORD=your-password-here

# Full connection string (built from above)
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/analystiq
